PORT=5000

# gemini | ollama (see .env.gemini.example vs local Ollama vars below)
AI_PROVIDER=gemini

# Gemini mode (online / Vercel)
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_AGENTS=5
GEMINI_MAX_PER_KEY=3

# Ollama mode (local). Examples after pull: qwen2.5-coder, llama3.1, llama3.1:8b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5-coder
# OLLAMA_TEMPERATURE=0.2
# OLLAMA_MAX_OUTPUT_TOKENS=2048

